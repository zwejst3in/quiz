from flask import Flask, request, render_template_string, url_for

app = Flask(__name__)

QUESTIONS = [
    {"question": "Capital of France?", "answer": "paris"},
    {"question": "2 + 2 = ?", "answer": ""},
    {"question": "Color of the sky on a clear day?", "answer": "blue"},
]

PAGE = """
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>Q&A Quiz</title>
</head>
<body>
  <h1>Q&A Quiz</h1>
  {% if feedback %}
    <p><strong>{{ feedback }}</strong></p>
  {% endif %}
  {% if question %}
    <form method="post">
      <p>Question {{ index + 1 }} of {{ total }}:</p>
      <p>{{ question }}</p>
      <input type="text" name="answer" autofocus />
      <input type="hidden" name="index" value="{{ index }}">
      <button type="submit">Send</button>
    </form>
  {% else %}
    <p>Done!</p>
    <a href="{{ url_for('quiz') }}">Restart</a>
  {% endif %}
</body>
</html>
"""

@app.route("/", methods=["GET", "POST"])
def quiz():
    feedback = None

    if request.method == "POST":
        index = int(request.form.get("index", "0"))
        user_answer = (request.form.get("answer") or "").strip().lower()
        correct = QUESTIONS[index]["answer"].lower()

        if user_answer == correct:
            feedback = "Correct!"
        else:
            feedback = f"Wrong – correct answer: {correct}"

        index += 1
    else:
        index = 0

    if index < len(QUESTIONS):
        q = QUESTIONS[index]["question"]
    else:
        q = None

    return render_template_string(
        PAGE,
        feedback=feedback,
        question=q,
        index=index,
        total=len(QUESTIONS),
    )

if __name__ == "__main__":
    app.run(host="0.0.0.0", port=5000)
